# Environment
NODE_ENV=production

# APP
VITE_APP_TITLE=my-app
VITE_APP_MODE=staging

# Public base path
VITE_BASE_PATH=./

# Public API
VITE_BASE_API=/stg-api
VITE_BASE_WS=/stg-ws
VITE_BASE_UI=/stg-ui

# Router mode,
# `hash` or `history`
VITE_ROUTE_MODE=hash

# Use
VITE_USE_DEBUG=false
VITE_USE_VCONSOLE=false
VITE_USE_MOCK=false
VITE_USE_LEGACY=false