# Environment
NODE_ENV=development

# APP
VITE_APP_TITLE=my-app
VITE_APP_MODE=testing

# Public base path
VITE_BASE_PATH=./

# Public API
VITE_BASE_API=/test-api
VITE_BASE_WS=/test-ws
VITE_BASE_UI=/test-ui

# Router mode,
# `hash` or `history`
VITE_ROUTE_MODE=hash

# Use
VITE_USE_DEBUG=true
VITE_USE_VCONSOLE=true
VITE_USE_MOCK=false
VITE_USE_LEGACY=false