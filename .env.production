# Environment
NODE_ENV=production

# Vite variables

# Title
VITE_TITLE=

# Public base path
VITE_BASE_PATH=./

# Public API
VITE_BASE_API=/prod-api

# Router mode, `hash` or `history`
VITE_ROUTER_MODE=hash

# Controlls
VITE_USE_DEBUG=false
VITE_USE_VCONSOLE=false
VITE_USE_MOCK=false
VITE_USE_LEGACY=false